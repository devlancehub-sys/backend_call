PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=lovecall

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ZEGOCLOUD Voice Call (ServerSecret NEVER expose to Flutter)
ZEGOCLOUD_APP_ID=0
ZEGOCLOUD_SERVER_SECRET=00000000000000000000000000000000
ZEGOCLOUD_TOKEN_TTL_SECONDS=3600

COMMISSION_PERCENTAGE=40
DEFAULT_HOST_RATE=10

# Admin panel API key (must match admin/src/environments/environment.ts)
ADMIN_API_KEY=local-admin-key
