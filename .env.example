PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=lovecall

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ZEGOCLOUD Voice Call (ServerSecret NEVER expose to Flutter)
ZEGOCLOUD_APP_ID=0
ZEGOCLOUD_SERVER_SECRET=00000000000000000000000000000000
ZEGOCLOUD_TOKEN_TTL_SECONDS=3600

COMMISSION_PERCENTAGE=40
DEFAULT_HOST_RATE=10

# Admin panel API key (must match admin/src/environments/environment.ts)
ADMIN_API_KEY=local-admin-key

# Production API base URL (apps + admin panel)
PUBLIC_API_URL=https://api.talkymate.in

# Firebase Cloud Messaging (HTTP v1 — recommended)
# Must match girls_app google-services.json → project_id
FIREBASE_PROJECT_ID=audiocallgirls
#
# NOT the same as google-services.json — download from Firebase Console:
# Project Settings → Service accounts → Generate new private key
# Paste minified JSON on one line, OR use a file path:
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=./audiocallgirls-firebase-adminsdk-fbsvc-1a1155016d.json

# Legacy fallback only (deprecated by Google):
# FIREBASE_SERVER_KEY=

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_TCsN7sYsT3zbCl
RAZORPAY_KEY_SECRET=yHGgDAGiWqs5ioe9mx23P4ti
